---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Meal Finder</title>
  </head>
  <body>
    <main>
      <section class="hero">
        <h1>Meal Finder</h1>
        <p>
          Build a request using ingredient, region, and category filters. The service will call external APIs and return a generated result page.
        </p>
      </section>

      <section class="card">
        <form id="meal-search-form" action="/results" method="get" class="grid" novalidate>
          <div class="grid two">
            <label>
              Main Ingredient
              <input type="text" name="main_ingredient" placeholder="chicken" maxlength="64" />
            </label>

            <label>
              Category
              <input type="text" name="category" placeholder="Vegetarian" maxlength="64" />
            </label>

            <label>
              Area
              <input type="text" name="area" placeholder="Italian" maxlength="64" />
            </label>

            <label>
              Ingredients To Exclude
              <input
                type="text"
                name="ingredients_to_exclude_input"
                placeholder="garlic, onion"
                maxlength="250"
              />
              <span class="inline-note">Use commas to separate multiple ingredients.</span>
            </label>
          </div>

          <div id="form-error" class="alert error" hidden></div>
          <button type="submit">Search Meal</button>
        </form>
      </section>
    </main>

    <script>
      const form = document.querySelector("#meal-search-form");
      const formError = document.querySelector("#form-error");

      const filterFieldNames = [
        "main_ingredient",
        "category",
        "area",
        "ingredients_to_exclude_input",
      ];

      const filterInputs = filterFieldNames
        .map((name) => form?.querySelector(`[name="${name}"]`))
        .filter((input) => input instanceof HTMLInputElement);

      const getActiveFilterNames = () => {
        const activeNames: string[] = [];

        filterInputs.forEach((input) => {
          if (input.value.trim().length > 0) {
            activeNames.push(input.name);
          }
        });

        return activeNames;
      };

      const updateFilterAvailability = () => {
        const activeNames = getActiveFilterNames();
        const lockToSingleFilter = activeNames.length === 1;
        const activeName = lockToSingleFilter ? activeNames[0] : "";

        filterInputs.forEach((input) => {
          input.disabled = lockToSingleFilter && input.name !== activeName;
        });
      };

      filterInputs.forEach((input) => {
        input.addEventListener("input", updateFilterAvailability);
      });
      updateFilterAvailability();

      form?.addEventListener("submit", (event) => {
        console.info("[Meal Finder] Submit triggered");
        event.preventDefault();

        if (!(form instanceof HTMLFormElement)) return;

        if (formError instanceof HTMLElement) {
          formError.hidden = true;
          formError.textContent = "";
        }

        const data = new FormData(form);
        const query = new URLSearchParams();

        const mainIngredient = String(data.get("main_ingredient") ?? "").trim();
        const category = String(data.get("category") ?? "").trim();
        const area = String(data.get("area") ?? "").trim();
        console.debug("[Meal Finder] Base filters prepared", {
          main_ingredient: mainIngredient,
          category,
          area,
        });

        const rawExclusions = String(data.get("ingredients_to_exclude_input") ?? "").trim();
        let exclusions: string[] = [];
        if (rawExclusions.length > 0) {
          exclusions = rawExclusions
            .split(",")
            .map((item) => item.trim())
            .filter((item, index, arr) => item.length > 0 && arr.indexOf(item) === index);

          if (exclusions.length === 0) {
            if (formError instanceof HTMLElement) {
              formError.hidden = false;
              formError.textContent = "Ingredients to exclude are invalid. Use comma-separated words.";
            }
            console.warn("[Meal Finder] Invalid exclusions input", { rawExclusions });
            return;
          }
          console.debug("[Meal Finder] Exclusions parsed", { exclusions });
        }

        const activeFiltersCount =
          (mainIngredient ? 1 : 0) +
          (category ? 1 : 0) +
          (area ? 1 : 0) +
          (exclusions.length > 0 ? 1 : 0);

        if (activeFiltersCount > 1) {
          if (formError instanceof HTMLElement) {
            formError.hidden = false;
            formError.textContent = "Please use only one filter at a time.";
          }
          console.warn("[Meal Finder] Multiple filters selected", {
            mainIngredient,
            category,
            area,
            exclusions,
          });
          return;
        }

        if (mainIngredient) query.append("main_ingredient", mainIngredient);
        if (category) query.append("category", category);
        if (area) query.append("area", area);
        exclusions.forEach((value) => query.append("ingredients_to_exclude", value));

        const destination = query.toString().length > 0 ? `/results?${query.toString()}` : "/results";
        console.info("[Meal Finder] Redirecting to results", {
          destination,
          query: query.toString(),
        });
        window.location.assign(destination);
      });
    </script>
  </body>
</html>
